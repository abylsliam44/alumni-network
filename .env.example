# ============================================
# Alumni Social Network - Environment Configuration
# ============================================
# Copy this file to .env for development or .env.prod for production
# IMPORTANT: Never commit .env or .env.prod files!

# ============================================
# Database (PostgreSQL)
# ============================================
POSTGRES_USER=alumni_user
POSTGRES_PASSWORD=alumni_password
POSTGRES_DB=alumni_db
# For docker-compose: use 'postgres' as host (container name)
# For local dev without docker: use 'localhost'
DATABASE_URL=postgresql://alumni_user:alumni_password@postgres:5432/alumni_db

# ============================================
# Security (REQUIRED - change in production!)
# ============================================
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_ACCESS_COOKIE_NAME=access_token
AUTH_REFRESH_COOKIE_NAME=refresh_token
# Production over HTTPS: true. Local HTTP development: false.
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=
# Production recommendation: false, unless you need Swagger/OpenAPI exposed.
ENABLE_OPENAPI=true

# ============================================
# Redis, Celery, DB pooling, rate limits
# ============================================
REDIS_CACHE_URL=redis://redis-cache:6379/0
REDIS_PUBSUB_URL=redis://redis-cache:6379/1
REDIS_RATE_LIMIT_URL=redis://redis-cache:6379/2
REDIS_CACHE_MAXMEMORY=256mb
CELERY_BROKER_URL=redis://redis-celery:6379/0
CELERY_RESULT_BACKEND=redis://redis-celery:6379/1
WEB_CONCURRENCY=1
CELERY_WORKER_CONCURRENCY=1
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
CACHE_DEFAULT_TTL_SECONDS=60
CACHE_DIRECTORY_TTL_SECONDS=45
CACHE_PROFILE_TTL_SECONDS=120
CACHE_CONVERSATIONS_TTL_SECONDS=15
CACHE_MESSAGES_TTL_SECONDS=30
CACHE_RECOMMENDATIONS_TTL_SECONDS=300
CACHE_OPPORTUNITIES_TTL_SECONDS=300
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_API_PER_MINUTE=180
RATE_LIMIT_AI_PER_MINUTE=20
RATE_LIMIT_MESSAGES_PER_MINUTE=60

# ============================================
# AI / LLM (optional but needed for AI features)
# ============================================
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# ============================================
# Vector Search (Qdrant)
# ============================================
# For docker-compose: use http://qdrant:6333
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ============================================
# OAuth (optional - for Google/LinkedIn login)
# ============================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ============================================
# CORS (for production, set your domain)
# ============================================
# Comma-separated list of allowed origins
# Example: http://yourdomain.com,https://yourdomain.com
BACKEND_CORS_ORIGINS=

# ============================================
# Frontend Configuration
# ============================================
# DEV (docker-compose.yml): Leave empty - Vite proxy handles API routing
# PROD (docker-compose.prod.yml): Leave empty - nginx proxy handles API routing
# Direct backend connection (no proxy): http://localhost:8010
VITE_API_URL=

# ============================================
# Video Calls / Jitsi
# ============================================
# Default meet.jit.si requires the first room moderator to authenticate with Jitsi.
# For production without that prompt, use a self-hosted Jitsi or JaaS (8x8.vc).
JITSI_DOMAIN=meet.jit.si
# JaaS only: vpaas-magic-cookie-...; backend will use room names as <AppID>/<room>.
JITSI_APP_ID=
# Optional override. JaaS example: https://8x8.vc/<AppID>/external_api.js
JITSI_EXTERNAL_API_URL=
# Optional JWT signing. Self-hosted token auth can use HS256 shared secret.
# JaaS uses RS256 private key + key id.
JITSI_JWT_SIGNING_KEY=
JITSI_JWT_SIGNING_KEY_FILE=
# Leave empty to infer HS256 for self-hosted Jitsi, RS256 for JaaS.
JITSI_JWT_ALGORITHM=
JITSI_JWT_KEY_ID=
JITSI_JWT_ISSUER=
JITSI_JWT_SUBJECT=
JITSI_JWT_AUDIENCE=jitsi
# Leave empty for exact room claim; use * only if your provider policy allows all rooms.
JITSI_JWT_ROOM_CLAIM=
JITSI_JWT_EXPIRE_MINUTES=60

# ============================================
# Storage
# ============================================
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE=5242880
MINIO_ENDPOINT=minio:9000
# Optional public storage base. Leave empty when using bundled /storage proxy.
# Example direct host: https://files.example.com
MINIO_PUBLIC_ENDPOINT=
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=alumni-files
MINIO_SECURE=false

# ============================================
# Email (optional - needed for event notifications)
# ============================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_FROM_NAME=Alumni Network
